#errorCatcher Echo
#encoding UTF-8
#import time
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=1124">
    #if $Extras.has_key('meta_title')
      <title>$Extras.meta_title</title>
    #else
      <title>$station.location</title>
    #end if
    <meta name="description" content="Up-to-date celestial data for $station.location.">
    <style>
      .label {
          font-size: 80%;
          vertical-align: top;
          text-align: right;
          padding-top: 4px;
          padding-right: 5px;
      }
      .data {
          font-weight: bold;
          font-size: 80%;
          vertical-align: top;
          text-align: left;
          padding-top: 4px;
      }
      .celestial_body {
          margin-bottom: 30px;
          float: left;
      }
    </style>
  </head>
  <body style="background-color:black;font-family:monospace;color:white;">
    #include "realtime_updater.inc"
    ## As of 3.0, all values are also computed at report generation time with
    ## the Skyfield almanac (formatted to match the javascript above, which
    ## then keeps them updated from loop data on every loop record).  Without
    ## an extended almanac (no Skyfield registration and no PyEphem), the
    ## cells are left empty and the javascript fills them, as in 2.x.
    #set $extras = $almanac.hasExtras
    #set $time_hms = "%I:%M:%S %p"
    #set $time_full = "%m/%d/%Y %I:%M:%S %p"
    ## Earth-to-body distances are in astronomical units; convert to the
    ## report's distance unit.
    #set $distance_label = str($unit.label.earthMoonDistance)
    ## These constants must match celestial.py's AU_KM/AU_MILES (a template
    ## cannot import the module; a test ties them together).
    #if $unit.unit_type.earthMoonDistance == 'km'
      #set $per_au = 1.4959787e8    ## kilometers per astronomical unit
    #else
      #set $per_au = 9.2955807e7    ## miles per astronomical unit
    #end if
    ## Anchor tomorrow/yesterday at local noon plus/minus one day: a flat
    ## 86400 seconds from "now" can land on the wrong calendar day across
    ## DST transitions (rise/set are computed for the day containing the
    ## almanac time, and noon +/- 24h is always inside the right day).
    #set $noon_today = time.mktime(time.localtime($current.dateTime.raw)[0:3] + (12, 0, 0, 0, 0, -1))
    #set $tomorrow = $almanac(almanac_time=$noon_today + 86400)
    #set $yesterday = $almanac(almanac_time=$noon_today - 86400)
    ## Total daylight, and its change since yesterday (same arithmetic as the
    ## javascript's daylightString).  $almanac.sun.visible needs WeeWX 5.2;
    ## on older WeeWX the cell is left for the javascript.
    #set $daylight_html = ''
    #if $extras
    #try
    #set $today_secs = $almanac.sun.visible.raw
    #set $yesterday_secs = $yesterday.sun.visible.raw
    #set $dl_hours = int($today_secs // 3600)
    #set $dl_minutes = int(($today_secs % 3600) // 60)
    #set $dl_seconds = int(round($today_secs % 60))
    #set $dl_delta = abs(int(round($yesterday_secs - $today_secs)))
    #set $dl_delta_minutes = int(($dl_delta % 3600) // 60)
    #set $dl_delta_seconds = int($dl_delta % 60)
    #if $today_secs < $yesterday_secs
      #set $dl_more_less = 'less'
    #elif $today_secs > $yesterday_secs
      #set $dl_more_less = 'more'
    #else
      #set $dl_more_less = 'same'
    #end if
    #set $daylight_html = "%d hours, %d minutes, %d seconds<br>%d minutes, %d seconds %s than yesterday" % ($dl_hours, $dl_minutes, $dl_seconds, $dl_delta_minutes, $dl_delta_seconds, $dl_more_less)
    #except
    #pass
    #end try
    #end if
    ## Distance to Proxima Centauri, in light years (needs the star catalog,
    ## i.e., stars = true; the cell is left for the javascript otherwise).
    #set $proxima_html = ''
    #if $extras
    #try
    #set $proxima_html = "%.2f light years" % ($almanac.proxima_centauri.earth_distance / 63241.077)
    #except
    #pass
    #end try
    #end if
    <div>
      <div>
        <table style="font-size:32px;width:100%;margin:auto;">
          <tr>
            <td style="text-align:left;width:220px;">
              <span id="last-update"></span>
            </td>
            <td style="text-align:center;">
              <h1 style="font-size:32px;text-decoration:underline;">
                #if $Extras.has_key('title')
                  $Extras.title
                #else
                  $station.location
                #end if
              </h1>
            </td>
            <td style="text-align:right;width:220px;">
              <span id="live-label"></span>
            </td>
          </tr>
        </table>
      </div>
    </div>
    <div style="font-size:20px;">
      <div class="celestial_body">
        <table class="celestial">
          <tr><th style="font-weight:bold;">&#9728; Sun</th><th></th></tr>
          <tr>
            <td class="label">Start astronomical twilight</td>
            <td class="data" id="current.astronomicalTwilightStart.raw">#if $extras#$($almanac(horizon=-18).sun(use_center=1).rise.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">Start nautical twilight</td>
            <td class="data" id="current.nauticalTwilightStart.raw">#if $extras#$($almanac(horizon=-12).sun(use_center=1).rise.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">Start civil twilight</td>
            <td class="data" id="current.civilTwilightStart.raw">#if $extras#$($almanac(horizon=-6).sun(use_center=1).rise.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">Sunrise</td>
            <td class="data" id="current.sunrise.raw">#if $extras#$($almanac.sunrise.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">Transit</td>
            <td class="data" id="current.sunTransit.raw">#if $extras#$($almanac.sun.transit.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">Sunset</td>
            <td class="data" id="current.sunset.raw">#if $extras#$($almanac.sunset.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">End civil twilight</td>
            <td class="data" id="current.civilTwilightEnd.raw">#if $extras#$($almanac(horizon=-6).sun(use_center=1).set.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">End nautical twilight</td>
            <td class="data" id="current.nauticalTwilightEnd.raw">#if $extras#$($almanac(horizon=-12).sun(use_center=1).set.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">End astronomical twilight</td>
            <td class="data" id="current.astronomicalTwilightEnd.raw">#if $extras#$($almanac(horizon=-18).sun(use_center=1).set.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">Azimuth</td>
            <td class="data" id="current.sunAzimuth.raw">#if $extras#$(("%.1f&deg;" % $almanac.sun.az))#end if#</td>
          </tr>
          <tr>
            <td class="label">Altitude</td>
            <td class="data" id="current.sunAltitude.raw">#if $extras#$(("%.1f&deg;" % $almanac.sun.alt))#end if#</td>
          </tr>
          <tr>
            <td class="label">Right ascension</td>
            <td class="data" id="current.sunRightAscension.raw">#if $extras#$(("%.1f&deg;" % $almanac.sun.ra))#end if#</td>
          </tr>
          <tr>
            <td class="label">Declination</td>
            <td class="data" id="current.sunDeclination.raw">#if $extras#$(("%.1f&deg;" % $almanac.sun.dec))#end if#</td>
          </tr>
          #if $extras and $almanac.next_equinox.raw < $almanac.next_solstice.raw
            ## The equinox is before the solstice. Display them in order.
            <tr>
              <td class="label">Equinox</td>
              <td class="data" id="current.nextEquinox">$almanac.next_equinox.format($time_full)</td>
            </tr>
            <tr>
              <td class="label">Solstice</td>
              <td class="data" id="current.nextSolstice">$almanac.next_solstice.format($time_full)</td>
            </tr>
          #else
            ## The solstice is before the equinox (or there is no extended
            ## almanac and the javascript will fill the cells in).
            <tr>
              <td class="label">Solstice</td>
              <td class="data" id="current.nextSolstice">#if $extras#$($almanac.next_solstice.format($time_full))#end if#</td>
            </tr>
            <tr>
              <td class="label">Equinox</td>
              <td class="data" id="current.nextEquinox">#if $extras#$($almanac.next_equinox.format($time_full))#end if#</td>
            </tr>
          #end if
          <tr>
            <td class="label">Total daylight</td>
            <td class="data" id="daylight">$daylight_html</td>
          </tr>
          <tr><td class="label">&nbsp;</td><td>&nbsp;</td></tr>
          <tr><th style="font-weight:bold;">&#9728; Tomorrow</th><th></th></tr>
          <tr>
            <td class="label">Sunrise</td>
            <td class="data" id="current.tomorrowSunrise.raw">#if $extras#$($tomorrow.sunrise.format($time_hms))#end if#</td>
          </tr>
          <tr>
            <td class="label">Sunset</td>
            <td class="data" id="current.tomorrowSunset.raw">#if $extras#$($tomorrow.sunset.format($time_hms))#end if#</td>
          </tr>
        </table>
      </div>
      <div>
        <table class="celestial">
          <tr><th style="font-weight:bold;">&#9789; Moon</th><th></th></tr>
          <tr>
            <td class="label">Moonrise</td>
            <td class="data" id="current.moonrise">#if $extras#$($almanac.moon.rise.format($time_full))#end if#</td>
          </tr>
          <tr>
            <td class="label">Transit</td>
            <td class="data" id="current.moonTransit">#if $extras#$($almanac.moon.transit.format($time_full))#end if#</td>
          </tr>
          <tr>
            <td class="label">Moonset</td>
            <td class="data" id="current.moonset">#if $extras#$($almanac.moon.set.format($time_full))#end if#</td>
          </tr>
          <tr>
            <td class="label">Azimuth</td>
            <td class="data" id="current.moonAzimuth.raw">#if $extras#$(("%.1f&deg;" % $almanac.moon.az))#end if#</td>
          </tr>
          <tr>
            <td class="label">Altitude</td>
            <td class="data" id="current.moonAltitude.raw">#if $extras#$(("%.1f&deg;" % $almanac.moon.alt))#end if#</td>
          </tr>
          <tr>
            <td class="label">Right ascension</td>
            <td class="data" id="current.moonRightAscension.raw">#if $extras#$(("%.1f&deg;" % $almanac.moon.ra))#end if#</td>
          </tr>
          <tr>
            <td class="label">Declination</td>
            <td class="data" id="current.moonDeclination.raw">#if $extras#$(("%.1f&deg;" % $almanac.moon.dec))#end if#</td>
          </tr>
          #if $extras and $almanac.next_full_moon.raw < $almanac.next_new_moon.raw
            <tr>
              <td class="label">Full moon</td>
              <td class="data" id="current.nextFullMoon">$almanac.next_full_moon.format($time_full)</td>
            </tr>
            <tr>
              <td class="label">New moon</td>
              <td class="data" id="current.nextNewMoon">$almanac.next_new_moon.format($time_full)</td>
            </tr>
          #else
            <tr>
              <td class="label">New moon</td>
              <td class="data" id="current.nextNewMoon">#if $extras#$($almanac.next_new_moon.format($time_full))#end if#</td>
            </tr>
            <tr>
              <td class="label">Full moon</td>
              <td class="data" id="current.nextFullMoon">#if $extras#$($almanac.next_full_moon.format($time_full))#end if#</td>
            </tr>
          #end if
          <tr>
            <td class="label">Phase</td>
            <td class="data"><span id="current.moonPhase">#if $extras#$($almanac.moon_phase)#end if#</span><br>
              <span id="current.moonFullness">#if $extras#$(('%s%% full' % $almanac.moon_fullness))#end if#</span></td>
          </tr>
          <tr><td class="label">&nbsp;</td><td>&nbsp;</td></tr>
          <tr><th style="font-weight:bold;">&#9793; Earth</th><th style="font-weight:bold;">to Heavenly Bodies</th></tr>
          <tr>
            <td class="label">&#9789; Moon</td>
            <td class="data" id="current.earthMoonDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.moon.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9728; Sun</td>
            <td class="data" id="current.earthSunDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.sun.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9791; Mercury</td>
            <td class="data" id="current.earthMercuryDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.mercury.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9792; Venus</td>
            <td class="data" id="current.earthVenusDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.venus.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9794; Mars</td>
            <td class="data" id="current.earthMarsDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.mars.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9795; Jupiter</td>
            <td class="data" id="current.earthJupiterDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.jupiter.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9796; Saturn</td>
            <td class="data" id="current.earthSaturnDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.saturn.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9797; Uranus</td>
            <td class="data" id="current.earthUranusDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.uranus.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9798; Neptune</td>
            <td class="data" id="current.earthNeptuneDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.neptune.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#9799; Pluto</td>
            <td class="data" id="current.earthPlutoDistance" style="text-align:right">#if $extras#$(("{:,.1f}".format($almanac.pluto.earth_distance * $per_au) + $distance_label))#end if#</td>
          </tr>
          <tr>
            <td class="label">&#10038; Proxima Centauri</td>
            <td class="data" id="current.earthProximaCentauriDistance.raw" style="text-align:right">$proxima_html</td>
          </tr>
        </table>
      </div>
      <div style='text-align:center;font-size:16px;font-style:italic;'>
        <br>
        Calculated with Skyfield and JPL's 421.bsp ephemeris.
      </div>
    </div>
  </body>
</html>
