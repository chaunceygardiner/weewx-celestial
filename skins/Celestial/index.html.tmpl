#errorCatcher Echo
#encoding UTF-8
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    #if $Extras.has_key('meta_title')
      <title>$Extras.meta_title</title>
    #else
      <title>$station.location</title>
    #end if
    <meta name="description" content="The live sky over $station.location.">
    ## All styling lives in celestial.css: Cheetah owns '#', so hex colors
    ## must never appear in this template or the javascript include.  The
    ## skin version tags the URL so browsers refetch the stylesheet after
    ## an upgrade (CopyGenerator re-copies copy_once files on every report
    ## first-run, but a browser would happily keep serving its cached copy
    ## of an unversioned URL).
    #set $css_href = 'celestial.css'
    #if $Extras.has_key('version')
    #set $css_href = 'celestial.css?v=' + str($Extras.version)
    #end if
    <link rel="stylesheet" href="$css_href">
  </head>
  <body>
    #include "realtime_updater.inc"
    ## The page is one live panel: the Geocentric.  The roster's distance,
    ## AU and altitude cells are dual-source -- first-painted here from
    ## whatever capable report almanac is installed (weewx-skyfield for
    ## full fidelity including Proxima Centauri, or PyEphem), then kept
    ## live from loop data by the javascript above.  The dial, the trails
    ## and the rate readouts are javascript-only: the dial draws on the
    ## first loop-data fetch, and the rates and trails need two loop
    ## packets to derive motion.  Without an extended almanac the roster
    ## first-paints empty and the javascript fills it, as always.
    #set $extras = $almanac.hasExtras
    ## Earth-to-body distances are raw astronomical units; convert to the
    ## report's distance unit.
    #set $distance_label = str($unit.label.windrun)
    ## Kilometers/miles per IAU astronomical unit; a test ties these to the
    ## javascript include's copies.  (windrun stands in for group_distance --
    ## this extension registers no observation types.)
    #if $unit.unit_type.windrun == 'km'
      #set $per_au = 1.4959787e8    ## kilometers per astronomical unit
    #else
      #set $per_au = 9.2955807e7    ## miles per astronomical unit
    #end if
    ## Station coordinates, hemisphere-lettered for the header; the
    ## latitude also feeds the javascript moon disc (lit-side flip).
    #set $lat_f = $station.stn_info.latitude_f
    #set $lon_f = $station.stn_info.longitude_f
    #set $lat_letter = 'N' if $lat_f >= 0 else 'S'
    #set $lon_letter = 'E' if $lon_f >= 0 else 'W'
    ## The roster bodies, nearest-tier first: moon and sun, the planets in
    ## orbital order, Proxima Centauri last.  Every cell of every row is
    ## individually guarded: an almanac that cannot serve one body (PyEphem
    ## has no Proxima; the built-in almanac has no extras at all) leaves
    ## that row's cells empty for the javascript, never breaks the page.
    #set $geo_bodies = ('moon', 'sun', 'mercury', 'venus', 'mars', 'jupiter', 'saturn', 'uranus', 'neptune', 'pluto', 'proxima_centauri')
    <div class="page">
      <header>
        <div>
          <h1>
            #if $Extras.has_key('title')
              $Extras.title
            #else
              Celestial <span class="over">over</span> $station.location
            #end if
          </h1>
          <div class="sub mono">
            $("%.2f&deg; %s &middot; %.2f&deg; %s" % (abs($lat_f), $lat_letter, abs($lon_f), $lon_letter))
            &middot; <span id="live-clock"></span>
            &middot; updated <span id="last-update"></span> <span id="live-label"></span>
          </div>
        </div>
      </header>

      <section>
        <h2 class="eyebrow">The geocentric &middot; live</h2>
        #if not $extras
        <p class="skyhint">Install
        <a href="https://github.com/chaunceygardiner/weewx-skyfield">weewx-skyfield</a>
        (strongly recommended, and required for Proxima Centauri) or PyEphem
        so the almanac can serve this panel's positions and distances.</p>
        #end if
        <div class="geo-body">
          <div>
            <svg id="dial" viewBox="0 0 660 660" role="img"
                 aria-label="Geocentric chart: bodies placed by compass azimuth and log distance from Earth"></svg>
            <p class="caption dialcaption">plan view &mdash; compass bearing, east to the
            right &middot; rings step &times;10 in distance &middot;
            solid&nbsp;=&nbsp;above the horizon, dashed&nbsp;=&nbsp;below &middot;
            trails show the last hour of motion</p>
          </div>
          <div class="roster mono">
            #for $body_name in $geo_bodies
            #set $display_name = 'proxima' if $body_name == 'proxima_centauri' else $body_name
            #set $dist_html = ''
            #set $au_html = ''
            #set $alt_html = ''
            #set $below_cls = ''
            #if $extras
            #try
            #set $body_obj = getattr($almanac, $body_name)
            #set $au_val = $body_obj.earth_distance
            #set $alt_val = $body_obj.alt
            #set $dist_html = "{:,.0f}".format($au_val * $per_au)
            #set $au_html = ("%.1f au" % $au_val) if $au_val >= 1000 else ("%.6f au" % $au_val)
            #set $alt_html = 'below horizon' if $alt_val < 0 else ("alt %.1f&deg;" % $alt_val)
            #set $below_cls = ' below' if $alt_val < 0 else ''
            #except
            #pass
            #end try
            #end if
            <div class="row$below_cls" id="geo-row-$body_name">
              <span class="bname"><span class="chip chip-$body_name"></span>$display_name</span>
              <span class="odo"><span id="almanac.${body_name}.earth_distance">$dist_html</span><span class="unit">$distance_label</span></span>
              <span class="rsub"><span id="geo-rate-$body_name"></span><span id="geo-au-$body_name">$au_html</span><span id="geo-alt-$body_name">$alt_html</span></span>
            </div>
            #end for
          </div>
        </div>
      </section>

      <footer>
        ## The credit must be true for whatever almanac actually serves the
        ## page, probed by capability: Proxima Centauri needs weewx-skyfield
        ## with its star catalog (the full credit); any other extended
        ## almanac gets the generic credit; the built-in almanac serves no
        ## live fields at all.
        #set $footer_credit = "Calculated with WeeWX's built-in almanac"
        #if $extras
        #set $footer_credit = "Calculated with the station's extended almanac (weewx-skyfield or PyEphem)"
        #try
        #silent $almanac.proxima_centauri.earth_distance
        #set $footer_credit = "Calculated with Skyfield, JPL's DE421 ephemeris and the Hipparcos star catalog (Credit: ESA)"
        #except
        #pass
        #end try
        #end if
        $footer_credit &middot; live via weewx-loopdata.
      </footer>
    </div>
  </body>
</html>
